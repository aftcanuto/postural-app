{
  "version": 2,
  "routes": [
    {
      "src": "/manifest.json",
      "dest": "/manifest.json",
      "headers": { "Content-Type": "application/manifest+json" }
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Service-Worker-Allowed": "/"
      }
    },
    {
      "src": "/icon-(.*)\\.png",
      "dest": "/icon-$1.png",
      "headers": { "Content-Type": "image/png" }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
